{
  "name": "webview-bundle-website",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "yarn gen:fumadocs",
    "dev": "next dev",
    "build": "next build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "format": "oxfmt",
    "gen:fumadocs": "fumadocs-mdx",
    "gen:references": "node scripts/generate-references.ts",
    "check:links": "node scripts/validate-links.ts"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@date-fns/tz": "1.5.0",
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@opennextjs/cloudflare": "^1.20.1",
    "@sentry/nextjs": "10.63.0",
    "@types/mdx": "2.0.14",
    "clsx": "2.1.1",
    "date-fns": "4.4.0",
    "fumadocs-core": "16.10.7",
    "fumadocs-mdx": "15.0.13",
    "fumadocs-ui": "16.10.7",
    "jose": "6.2.3",
    "next": "^16.2.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "^24",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "oxlint-tsgolint": "0.24.0",
    "tailwindcss": "4.3.2",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "wrangler": "4.107.0"
  },
  "packageManager": "yarn@4.17.0"
}
